# Copy this file to `.env` and fill in your own values.
# MySQL Database Connection
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=starride

# Set to true when using a managed/cloud MySQL host that requires TLS
# (e.g. Aiven, Railway, PlanetScale). Leave false for local MySQL.
MYSQL_SSL=false

# Server Port (cloud hosts set this automatically; local defaults to 3000)
PORT=3000
